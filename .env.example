# =============================================================================
# BACKEND (Express + MySQL) — runs on your Mac now, GoDaddy VPS in production
# Frontend React is hosted on GitHub Pages (not on this server).
# =============================================================================
#
# Quick start (local desktop):
#   cp .env.example .env
#   ./setup_database.sh
#   npm install && cd client && npm install && cd ..
#   npm start                    # API http://localhost:3100
#   npm run dev:client           # React http://localhost:5180 → proxies /api
#
# GitHub Pages shop: https://zub165.github.io/Clothing/shop/
#   Must allow CORS from GitHub (included below).
#
# =============================================================================

DB_HOST=localhost
DB_USER=clothing_user
DB_PASSWORD=your_password_here
DB_NAME=clothing_business
DB_PORT=3306

PORT=3100
JWT_SECRET=dev-change-me-local-only
NODE_ENV=development

# Include GitHub Pages + local React dev. Add VPS domain when ready.
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180,http://localhost:3100,https://zub165.github.io

BACKUP_DIR=./backups
MAX_BACKUPS=10
