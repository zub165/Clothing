# ========== LOCAL DEVELOPMENT ==========
# 1. cp .env.example .env
# 2. ./setup_database.sh   (MySQL + tables + writes .env)
# 3. npm install && cd client && npm install && cd ..
# 4. npm start           → API http://localhost:3100
# 5. npm run dev:client    → React http://localhost:5180 (proxies /api → 3100)
#
# React env: cp client/.env.example client/.env (leave VITE_API_URL empty for proxy)

# Database
DB_HOST=localhost
DB_USER=clothing_user
DB_PASSWORD=your_password_here
DB_NAME=clothing_business
DB_PORT=3306

# API (port 3100 — avoids conflicts with 3000, 5173, etc.)
PORT=3100
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180,http://localhost:3100
NODE_ENV=development

BACKUP_DIR=./backups
MAX_BACKUPS=10

# Production VPS: use .env.production.example instead (see deploy/GODADDY_VPS.md) 