# GoDaddy VPS — BACKEND ONLY (API + MySQL). React stays on GitHub Pages.
# Copy to .env on the server:  cp .env.production.example .env

DB_HOST=localhost
DB_USER=clothing_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=clothing_business
DB_PORT=3306

PORT=3100
NODE_ENV=production
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# GitHub Pages frontend + your API domain
CORS_ORIGINS=https://zub165.github.io,https://yourdomain.com

# Do not build React on VPS (frontend is on GitHub Pages)
SKIP_CLIENT_BUILD=true

BACKUP_DIR=./backups
MAX_BACKUPS=10
