# Local development (npm run dev on port 5180)
# Leave VITE_API_URL empty — Vite proxies /api → http://localhost:3100
VITE_API_URL=

# Optional: call API directly (no proxy), e.g. mobile testing on LAN
# VITE_API_URL=http://127.0.0.1:3100

# Production build on VPS (npm run build)
# Leave empty — React is served from same host as Express (/shop + /api)

# GitHub Pages: use .env.github-pages or VITE_BASE_PATH=/Clothing/shop/
