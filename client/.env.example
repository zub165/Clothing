# =============================================================================
# REACT FRONTEND ONLY — backend runs separately (see root .env.example)
# =============================================================================
#
# MODE A — Local desktop dev (recommended day-to-day)
#   Terminal 1: npm start              → Express + MySQL on :3100
#   Terminal 2: npm run dev:client     → React on :5180, proxies /api → :3100
#   Leave VITE_API_URL empty below.
#
# MODE B — GitHub Pages (static host)
#   Push to main → Actions deploys client/dist to Pages.
#   Set GitHub secret VITE_API_URL when VPS is live, e.g. https://yourdomain.com
#   Until then, shop UI loads but needs your desktop API or VPS for data.
#
# MODE C — Optional: test built shop against local API (same Mac only)
#   VITE_API_URL=http://127.0.0.1:3100
#   npm run build && npm run preview
#
# =============================================================================

VITE_API_URL=

# Only for GitHub Pages builds (see .env.github-pages)
# VITE_BASE_PATH=/Clothing/shop/
