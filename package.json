{
  "name": "clothing-business-db-manager",
  "version": "1.0.0",
  "description": "Database management interface for clothing business",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:client": "npm run dev --prefix client",
    "build:client": "npm run build --prefix client",
    "build": "npm run build:client",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "dev:local": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "db:migrate": "bash deploy/migrate-db.sh",
    "deploy:release": "bash deploy/release.sh",
    "setup:env": "cp -n .env.example .env 2>/dev/null; cp -n client/.env.example client/.env 2>/dev/null; echo 'Edit .env and run ./setup_database.sh'"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.2",
    "exceljs": "^4.4.0",
    "multer": "^1.4.5-lts.1",
    "chart.js": "^4.4.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.0"
  }
} 